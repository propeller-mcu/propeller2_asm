'tx.p2
DAT
org 0

_CLKFREQ        equ 180000000
BAUD_RATE       equ 2000000
TRANSMISSION_PIN equ 62
BIT_PERIOD      equ _CLKFREQ / BAUD_RATE
BAUD_MODE1      equ BIT_PERIOD << 16
BAUD_MODE       equ BAUD_MODE1 | 7

wrpin  ##(P_ASYNC_TX | P_OE), #TRANSMISSION_PIN
wxpin  ##BAUD_MODE, #TRANSMISSION_PIN
wypin  #1, #TRANSMISSION_PIN
dirh   #TRANSMISSION_PIN
wypin  #0, #TRANSMISSION_PIN

loop:
jmp #loop
